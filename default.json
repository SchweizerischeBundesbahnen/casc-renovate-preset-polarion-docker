{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate preset for Polarion Docker repositories maintained by the SBB Polarion Team",
  "extends": [
    "github>SchweizerischeBundesbahnen/casc-renovate-preset-polarion"
  ],
  "enabledManagers": [
    "dockerfile",
    "docker-compose",
    "pep621",
    "pre-commit",
    "github-actions",
    "custom.regex"
  ],
  "constraints": {
    "python": ">=3.12"
  },
  "packageRules": [
    {
      "description": "Python minor and major version updates require manual review",
      "matchManagers": [
        "dockerfile",
        "pep621"
      ],
      "matchPackageNames": [
        "python"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "automerge": false,
      "prCreation": "immediate"
    }
  ]
}